@model IEnumerable<BasicExpenseTracker.Models.Expense>

@{
    ViewData["Title"] = "Expense Tracker";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>💰 My Expense Tracker</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add New Expense</a>
    </div>

    <div class="card bg-light mb-4">
        <div class="card-body">
            <h5 class="card-title text-muted">Total Money Spent</h5>
            <h2 class="text-danger">$@ViewBag.TotalSpent?.ToString("F2")</h2>
        </div>
    </div>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Date</th>
                <th>Amount</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td><span class="badge bg-secondary">@item.Category</span></td>
                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                    <td class="text-danger font-weight-bold">$@item.Amount.ToString("F2")</td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No expenses recorded yet. Click add to start!</td>
                </tr>
            }
        </tbody>
    </table>
</div>
